type WalletRequest = 
 record {
   account: Account;
   cursor: opt nat;
   filter: opt text;
   limit: opt nat;
 };
type WalletReceipt = 
 record {
   account: Account;
   entries: vec WalletEntry;
   nextCursor: opt nat;
   witness: opt text;
 };
type WalletHolding = 
 variant {
   fungible: record {
               amount: nat;
               meta: NoMetadata;
             };
   nonfungible: record {
                  id: nat;
                  meta: NoMetadata;
                };
 };
type WalletError = variant {
                     accountNotAuthorized:
                      record {
                        account: Account;
                        caller: principal;
                      };};
type WalletEntry = 
 record {
   displayAsset: opt NodeId;
   displayLabel: opt text;
   holding: WalletHolding;
   node: NodeId;
   status: HoldingStatus;
 };
type TransferFromError = 
 variant {
   BadBurn: record {min_burn_amount: nat;};
   BadFee: record {expected_fee: nat;};
   CreatedInFuture: record {ledger_time: nat64;};
   Duplicate: record {duplicate_of: nat;};
   GenericError: record {
                   error_code: nat;
                   message: text;
                 };
   InsufficientAllowance: record {allowance: nat;};
   InsufficientFunds: record {balance: nat;};
   TemporarilyUnavailable;
   TooOld;
 };
type TransferError = 
 variant {
   BadBurn: record {min_burn_amount: nat;};
   BadFee: record {expected_fee: nat;};
   CreatedInFuture: record {ledger_time: nat64;};
   Duplicate: record {duplicate_of: nat;};
   GenericError: record {
                   error_code: nat;
                   message: text;
                 };
   InsufficientFunds: record {balance: nat;};
   TemporarilyUnavailable;
   TooOld;
 };
type Subaccount = blob;
type Result_4 = 
 variant {
   err: WalletError;
   ok: WalletReceipt;
 };
type Result_3 = 
 variant {
   err: ExecuteError;
   ok: Receipt;
 };
type Result_2 = 
 variant {
   err: ExecuteError;
   ok: Quote;
 };
type Result_1 = 
 variant {
   err: IcrcDepositError;
   ok: IcrcDepositReceipt;
 };
type Result = 
 variant {
   err: IcrcWithdrawError;
   ok: IcrcWithdrawReceipt;
 };
type Receipt = 
 record {
   account: Account;
   edgeId: EdgeId;
   executedAt: int;
   fees: vec BasketEntry;
   input: vec BasketEntry;
   output: vec BasketEntry;
   positionInputs: vec PositionEffect;
   positionOutputs: vec PositionEffect;
   positionRemaining: vec PositionEffect;
   witness: opt text;
 };
type QuoteRequest = 
 record {
   account: Account;
   edgeId: EdgeId;
   intent: Intent;
 };
type Quote = 
 record {
   account: Account;
   edgeId: EdgeId;
   expiresAt: opt int;
   fees: vec BasketEntry;
   input: vec BasketEntry;
   output: vec BasketEntry;
   positionInputs: vec PositionEffect;
   positionOutputs: vec PositionEffect;
   preconditions: opt text;
   witness: opt text;
 };
type PositionEffect = 
 record {
   amount: nat;
   metadata: opt text;
   node: NodeId;
   positionId: opt nat;
   unlockAt: opt int;
 };
type PendingIcrcWithdrawal = 
 record {
   account: Account;
   amount: nat;
   debitAmount: nat;
   fee: nat;
   ledger: LedgerId;
   to: Account__1;
 };
type NodeShape = 
 record {
   displayAsset: opt NodeId;
   displayLabel: opt text;
   form: NodeForm;
   nodeId: NodeId;
   risk: opt text;
 };
type NodeId = 
 variant {
   ledger: LedgerId;
   local: blob;
 };
type NodeForm = 
 variant {
   fungible;
   nonfungible;
 };
type NoMetadata = null;
type LedgerReject = record {message: text;};
type LedgerId = principal;
type Intent = 
 record {
   amount: nat;
   extension: opt text;
   positionId: opt nat;
 };
type IcrcWithdrawRequest = 
 record {
   account: Account;
   amount: nat;
   ledger: LedgerId;
   to: Account__1;
 };
type IcrcWithdrawReceipt = 
 record {
   account: Account;
   amount: nat;
   balanceAfter: nat;
   debitAmount: nat;
   fee: nat;
   ledger: LedgerId;
   to: Account__1;
   txIndex: nat;
 };
type IcrcWithdrawError = 
 variant {
   accountNotAuthorized: record {
                           account: Account;
                           caller: principal;
                         };
   icrcFeeRejected: LedgerReject;
   icrcTransferErr: TransferError;
   icrcTransferRejected: LedgerReject;
   insufficientLocalBalance;
   ledgerNotSupported: LedgerId;
   withdrawInProgress: PendingIcrcWithdrawal;
   zeroAmount;
 };
type IcrcDepositRequest = 
 record {
   account: Account;
   amount: nat;
   from: Account__1;
   ledger: LedgerId;
 };
type IcrcDepositReceipt = 
 record {
   account: Account;
   amount: nat;
   balanceAfter: nat;
   from: Account__1;
   ledger: LedgerId;
   txIndex: nat;
 };
type IcrcDepositError = 
 variant {
   accountNotAuthorized: record {
                           account: Account;
                           caller: principal;
                         };
   amountTooLow: record {
                   amount: nat;
                   minAmount: nat;
                 };
   icrcTransferFromErr: TransferFromError;
   icrcTransferFromRejected: LedgerReject;
   ledgerNotSupported: LedgerId;
   sourceOwnerMismatch: record {
                          caller: principal;
                          fromOwner: principal;
                        };
   zeroAmount;
 };
type HoldingStatus = 
 variant {
   available;
   locked: record {unlockAt: opt int;};
   pending: record {unlockAt: opt int;};
 };
type Guard = 
 record {
   deadline: opt int;
   extension: opt text;
   maxDebt: opt nat;
   maxFee: vec BasketEntry;
   maxPriceImpact: opt nat;
   maxSpend: vec BasketEntry;
   minHealth: opt nat;
   minReceive: vec BasketEntry;
   minShares: opt nat;
 };
type ExecuteRequest = 
 record {
   guard: Guard;
   quote: Quote;
 };
type ExecuteError = 
 variant {
   accountNotAuthorized: record {
                           account: Account;
                           caller: principal;
                         };
   edgeNotLive: DiscoveryStatus;
   expiredQuote;
   guardRejected;
   insufficientInput;
   invalidAmount;
   protocolSpecific: text;
   quoteReceiptMismatch;
   unknownEdge;
 };
type EdgeShape = 
 record {
   displayLabel: opt text;
   edgeId: EdgeId;
   inputNodes: vec NodeId;
   outputNodes: vec NodeId;
   risk: opt text;
 };
type EdgeId = 
 record {
   id: nat;
   namespace: text;
   scope: CanisterId;
 };
type DiscoveryStatus = 
 variant {
   insufficientInput;
   live;
   notMature: record {unlockAt: int;};
   paused;
   protocolSpecific: text;
   unauthorized;
 };
type DiscoveryEdge = 
 record {
   edge: EdgeShape;
   status: DiscoveryStatus;
 };
type Discovery = 
 record {
   account: Account;
   edges: vec DiscoveryEdge;
   nextCursor: opt nat;
   nodes: vec NodeShape;
   witness: opt text;
 };
type DiscoverRequest = 
 record {
   account: Account;
   cursor: opt nat;
   filter: opt text;
   limit: opt nat;
 };
type DexPrincipalLpActor = 
 service {
   pool_state: () ->
    (record {
       reserveA: nat;
       reserveB: nat;
       totalLp: nat;
     }) query;
   spi_100_account: (wallet: principal, id: nat) -> (opt Account) query;
   spi_101_wallet: (request: WalletRequest) -> (Result_4) query;
   spi_102_discover: (request: DiscoverRequest) -> (Discovery) query;
   spi_102_execute: (request: ExecuteRequest) -> (Result_3);
   spi_102_quote: (request: QuoteRequest) -> (Result_2) query;
   spi_103_icrc_deposit: (request: IcrcDepositRequest) -> (Result_1);
   spi_103_icrc_withdraw: (request: IcrcWithdrawRequest) -> (Result);
 };
type CanisterId = principal;
type BasketEntry = 
 record {
   amount: nat;
   node: NodeId;
 };
type Account__1 = 
 record {
   owner: principal;
   subaccount: opt Subaccount;
 };
type Account = blob;
service : (tokenA: principal, tokenB: principal, _lpShare: principal, swapFeeBps: nat) -> DexPrincipalLpActor
