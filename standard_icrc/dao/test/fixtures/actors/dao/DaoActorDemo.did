type WithdrawRequest = 
 record {
   amount: nat;
   ledger: principal;
   subject: principal;
   to: Account;
 };
type WithdrawReceipt = 
 record {
   amount: nat;
   balanceAfter: nat;
   debitAmount: nat;
   fee: nat;
   ledger: principal;
   subject: principal;
   to: Account;
   txIndex: nat;
 };
type WithdrawError = 
 variant {
   insufficientLocalBalance;
   ledgerFeeRejected: LedgerReject;
   ledgerNotSupported: principal;
   ledgerTransferErr: TransferError;
   ledgerTransferRejected: LedgerReject;
   subjectNotAuthorized: record {
                           caller: principal;
                           subject: principal;
                         };
   withdrawInProgress: PendingWithdrawal;
   zeroAmount;
 };
type VoteReceipt = 
 record {
   choice: VoteChoice;
   id: nat;
   noVotes: nat;
   voter: principal;
   weight: nat;
   yesVotes: nat;
 };
type VoteInfo = 
 record {
   choice: opt VoteChoice;
   hasVoted: bool;
   lockedStake: nat;
   voteWeight: nat;
 };
type VoteError = 
 variant {
   alreadyVoted;
   noVotingPower;
   proposalNotFound;
   proposalNotOpen;
   stakeLockActive: record {
                      now: int;
                      unlockAt: int;
                    };
   subjectNotAuthorized: record {
                           caller: principal;
                           subject: principal;
                         };
   votingPeriodEnded: record {
                        deadline: int;
                        now: int;
                      };
 };
type VoteChoice = 
 variant {
   no;
   yes;
 };
type UnstakeError = 
 variant {
   cooldownActive: record {
                     now: int;
                     unlockAt: int;
                   };
   insufficientActiveStake;
   noPendingUnstake;
   stakeLockedForVote: record {
                         activeStake: nat;
                         lockedStake: nat;
                       };
   subjectNotAuthorized: record {
                           caller: principal;
                           subject: principal;
                         };
   unstakeAlreadyPending;
   zeroAmount;
 };
type TransferFromError = 
 variant {
   BadBurn: record {min_burn_amount: nat;};
   BadFee: record {expected_fee: nat;};
   CreatedInFuture: record {ledger_time: nat64;};
   Duplicate: record {duplicate_of: nat;};
   GenericError: record {
                   error_code: nat;
                   message: text;
                 };
   InsufficientAllowance: record {allowance: nat;};
   InsufficientFunds: record {balance: nat;};
   TemporarilyUnavailable;
   TooOld;
 };
type TransferError = 
 variant {
   BadBurn: record {min_burn_amount: nat;};
   BadFee: record {expected_fee: nat;};
   CreatedInFuture: record {ledger_time: nat64;};
   Duplicate: record {duplicate_of: nat;};
   GenericError: record {
                   error_code: nat;
                   message: text;
                 };
   InsufficientFunds: record {balance: nat;};
   TemporarilyUnavailable;
   TooOld;
 };
type StakeReceipt = 
 record {
   activeStake: nat;
   amount: nat;
   liquidBalance: nat;
   votingPowerUnlockAt: int;
 };
type StakeInfo = 
 record {
   activeStake: nat;
   activeVoteLock: nat;
   liquid: nat;
   pendingUnstake: nat;
   pendingWithdraw: nat;
   proposalBond: nat;
   unlockAt: opt int;
   votingPowerUnlockAt: opt int;
 };
type StakeError = 
 variant {
   insufficientLiquidBalance;
   subjectNotAuthorized: record {
                           caller: principal;
                           subject: principal;
                         };
   zeroAmount;
 };
type Result__1_1 = 
 variant {
   err: DepositError;
   ok: DepositReceipt;
 };
type Result__1 = 
 variant {
   err: WithdrawError;
   ok: WithdrawReceipt;
 };
type Result_6 = 
 variant {
   err: UnstakeError;
   ok: ClaimUnstakeReceipt;
 };
type Result_5 = 
 variant {
   err: CloseError;
   ok: CloseReceipt;
 };
type Result_4 = 
 variant {
   err: ProposalError;
   ok: ProposalReceipt;
 };
type Result_3 = 
 variant {
   err: ExecuteError;
   ok: ExecuteReceipt;
 };
type Result_2 = 
 variant {
   err: UnstakeError;
   ok: RequestUnstakeReceipt;
 };
type Result_1 = 
 variant {
   err: StakeError;
   ok: StakeReceipt;
 };
type Result = 
 variant {
   err: VoteError;
   ok: VoteReceipt;
 };
type RequestUnstakeReceipt = 
 record {
   activeStake: nat;
   amount: nat;
   pendingUnstake: nat;
   unlockAt: int;
 };
type ProposalWindow = 
 record {
   maxProposals: nat;
   nextProposalId: nat;
 };
type ProposalStatus = 
 variant {
   executed;
   failed;
   open;
   passed;
   stale;
 };
type ProposalReceipt = 
 record {
   configVersion: nat;
   createdAt: int;
   deadline: int;
   id: nat;
   proposer: principal;
   quorumVotes: nat;
   snapshotActiveStake: nat;
 };
type ProposalError = 
 variant {
   invalidConfigAction;
   proposalCapacityReached;
   proposalThresholdNotMet;
   stakeLockActive: record {
                      now: int;
                      unlockAt: int;
                    };
   stakeLockedForVote: record {
                         activeStake: nat;
                         lockedStake: nat;
                       };
   subjectNotAuthorized: record {
                           caller: principal;
                           subject: principal;
                         };
 };
type Proposal = 
 record {
   action: ConfigAction;
   bond: nat;
   configVersion: nat;
   createdAt: int;
   deadline: int;
   id: nat;
   noVotes: nat;
   proposer: text;
   quorumVotes: nat;
   snapshotActiveStake: nat;
   status: ProposalStatus;
   yesVotes: nat;
 };
type PendingWithdrawal__1 = 
 record {
   amount: nat;
   createdAtTime: nat;
   debitAmount: nat;
   fee: nat;
   operationId: nat;
 };
type PendingWithdrawal = 
 record {
   amount: nat;
   debitAmount: nat;
   fee: nat;
   ledger: principal;
   subject: principal;
   to: Account;
 };
type LedgerReject = record {message: text;};
type ExecuteReceipt = 
 record {
   applied: bool;
   config: Config;
   configVersion: nat;
   id: nat;
 };
type ExecuteError = 
 variant {
   alreadyExecuted;
   invalidConfigAction;
   proposalNotFound;
   proposalNotPassed;
 };
type DepositRequest = 
 record {
   amount: nat;
   from: Account;
   ledger: principal;
   subject: principal;
 };
type DepositReceipt = 
 record {
   amount: nat;
   balanceAfter: nat;
   from: Account;
   ledger: principal;
   subject: principal;
   txIndex: nat;
 };
type DepositError = 
 variant {
   amountTooLow: record {
                   amount: nat;
                   minAmount: nat;
                 };
   ledgerNotSupported: principal;
   ledgerTransferFromErr: TransferFromError;
   ledgerTransferFromRejected: LedgerReject;
   sourceOwnerMismatch: record {
                          caller: principal;
                          fromOwner: principal;
                        };
   subjectNotAuthorized: record {
                           caller: principal;
                           subject: principal;
                         };
   zeroAmount;
 };
type DaoTotals = 
 record {
   totalActiveStake: nat;
   totalLiquid: nat;
   totalPendingUnstake: nat;
   totalPendingWithdraw: nat;
   totalProposalBonds: nat;
   totalSupply: nat;
 };
type DaoActorDemo = 
 service {
   claim_unstaked: (subject: principal) -> (Result_6);
   close: (id: nat) -> (Result_5);
   config_version: () -> (nat) query;
   create_proposal: (subject: principal, action: ConfigAction) -> (Result_4);
   dao_totals: () -> (DaoTotals) query;
   execute: (id: nat) -> (Result_3);
   governance_ledger: () -> (principal) query;
   max_proposals: () -> (nat) query;
   next_proposal_id: () -> (nat) query;
   pending_withdrawal: (user: principal) -> (opt PendingWithdrawal__1) query;
   proposal: (id: nat) -> (opt Proposal) query;
   proposal_config: () -> (Config) query;
   proposal_window: () -> (ProposalWindow) query;
   request_unstake: (subject: principal, amount: nat) -> (Result_2);
   spi_101_balance: (request: BalanceRequest) -> (BalanceReceipt) query;
   spi_101_deposit: (request: DepositRequest) -> (Result__1_1);
   spi_101_withdraw: (request: WithdrawRequest) -> (Result__1);
   stake: (subject: principal, amount: nat) -> (Result_1);
   stake_info: (user: principal) -> (StakeInfo) query;
   vote: (subject: principal, id: nat, choice: VoteChoice) -> (Result);
   vote_info: (id: nat, user: principal) -> (VoteInfo) query;
   voting_power: (user: principal) -> (nat) query;
 };
type ConfigAction = 
 variant {
   setConfig: Config;
   setProposalThreshold: nat;
   setQuorum: nat;
 };
type Config = 
 record {
   proposalThreshold: nat;
   quorumVotes: nat;
 };
type CloseReceipt = 
 record {
   id: nat;
   noVotes: nat;
   quorumVotes: nat;
   status: ProposalStatus;
   yesVotes: nat;
 };
type CloseError = 
 variant {
   proposalNotFound;
   proposalNotOpen;
   votingPeriodActive: record {
                         deadline: int;
                         now: int;
                       };
 };
type ClaimUnstakeReceipt = 
 record {
   amount: nat;
   liquidBalance: nat;
 };
type BalanceRequest = record {subject: principal;};
type BalanceReceipt = 
 record {
   entries: vec BalanceEntry;
   subject: principal;
 };
type BalanceKey = principal;
type BalanceEntry = 
 record {
   BalanceKey;
   nat;
 };
type Account = 
 record {
   owner: principal;
   subaccount: opt blob;
 };
service : (governanceLedger: principal, initialQuorumVotes: nat, initialProposalThreshold: nat) -> DaoActorDemo
