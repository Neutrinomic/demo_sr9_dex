  public func controllerRemoveLedgerPreservesAccountingBalance(
    dex : Dex.State,
    caller : Principal,
    ledger : Principal
  ) : Types.Result<(), Types.ControllerLedgerError>
    requires Dex.accountingBalanced(dex, ledger);
    ensures Dex.accountingBalanced(dex, ledger);
  {
    let beforeNet = Dex.ledgerNet(dex, ledger);
    let beforeObligation = Dex.localObligation(dex, ledger);
    let beforePending = Dex.pendingOut(dex, ledger);
    let beforeDust = Dex.abandonedDust(dex, ledger);
    assert beforeNet == beforeObligation + beforePending + beforeDust;
    let out = Dex.controllerRemoveLedger(dex, caller, ledger);
    unchangedDeltasPreserveAccountingBalance(
      beforeNet,
      beforeObligation,
      beforePending,
      beforeDust,
      Dex.ledgerNet(dex, ledger),
      Dex.localObligation(dex, ledger),
      Dex.pendingOut(dex, ledger),
      Dex.abandonedDust(dex, ledger)
    );
    assert Dex.accountingBalanced(dex, ledger);
    out
  };

  public func abandonDustReceiptFacts(
    dex : Dex.State,
    caller : Principal,
    ledger : Principal
  ) : Types.Result<Types.DustAbandonReceipt, Types.DustAbandonError>
    requires true;
    ensures switch (result) {
      case (#ok receipt) {
        receipt.ledger == ledger and
        receipt.user == caller and
        receipt.balanceKey == AssetKey.ledger(ledger) and
        receipt.abandonedAmount > 0 and
        receipt.abandonedAmount <= receipt.fee and
        receipt.abandonedDustTotal == Dex.abandonedDust(dex, ledger) and
        receipt.abandonedDustTotal >= receipt.abandonedAmount
      };
      case (#err(_)) { true }
    };
  {
    Dex.abandonDust(dex, caller, ledger)
  };

  public func createPoolMarksLedgersAsHavingPool(
    dex : Dex.State,
    caller : Principal,
    ledgerA : Principal,
    ledgerB : Principal
  ) : Types.Result<Types.PoolInfo, Types.CreatePoolError>
    requires true;
    ensures Dex.controllerOf(dex) == old(Dex.controllerOf(dex));
    ensures switch (result) {
      case (#ok(_)) {
        Dex.ledgerHasPool(dex, ledgerA) and
        Dex.ledgerHasPool(dex, ledgerB)
      };
      case (#err(_)) { true }
    };
  {
    Dex.createPool(dex, caller, ledgerA, ledgerB)
  };

  public func controllerRemoveLedgerLeavesNoPool(
    dex : Dex.State,
    caller : Principal,
    ledger : Principal
  ) : Types.Result<(), Types.ControllerLedgerError>
    requires true;
    ensures Dex.controllerOf(dex) == old(Dex.controllerOf(dex));
    ensures switch (result) {
      case (#ok(_)) { not Dex.ledgerHasPool(dex, ledger) };
      case (#err(_)) { true }
    };
  {
    Dex.controllerRemoveLedger(dex, caller, ledger)
  };

  public func swapPreservesLedgerNet(
    dex : Dex.State,
    caller : Principal,
    ledgerIn : Principal,
    ledgerOut : Principal,
    amountIn : Nat,
    minAmountOut : Nat
  ) : Types.Result<Types.SwapReceipt, Types.SwapError>
    requires true;
    ensures Dex.controllerOf(dex) == old(Dex.controllerOf(dex));
    ensures Dex.ledgerNet(dex, ledgerIn) == old(Dex.ledgerNet(dex, ledgerIn));
    ensures Dex.ledgerNet(dex, ledgerOut) == old(Dex.ledgerNet(dex, ledgerOut));
  {
    Dex.swap(dex, caller, ledgerIn, ledgerOut, amountIn, minAmountOut)
  };

  public func failedSwapPreservesInputBalance(
    dex : Dex.State,
    caller : Principal,
    ledgerIn : Principal,
    ledgerOut : Principal,
    amountIn : Nat,
    minAmountOut : Nat
  ) : Types.Result<Types.SwapReceipt, Types.SwapError>
    requires true;
    ensures switch (result) {
      case (#ok(_)) { true };
      case (#err(_)) {
        Dex.localBalance(dex, caller, AssetKey.ledger(ledgerIn)) ==
          old(Dex.localBalance(dex, caller, AssetKey.ledger(ledgerIn)))
      }
    };
  {
    Dex.swap(dex, caller, ledgerIn, ledgerOut, amountIn, minAmountOut)
  };

  public func liquidityPreservesLedgerNet(
    dex : Dex.State,
    caller : Principal,
    request : Types.LiquidityRequest
  ) : Types.Result<Types.LiquidityReceipt, Types.LiquidityError>
    requires true;
    ensures Dex.controllerOf(dex) == old(Dex.controllerOf(dex));
    ensures switch (request) {
      case (#add req) {
        Dex.ledgerNet(dex, req.ledgerA) == old(Dex.ledgerNet(dex, req.ledgerA)) and
        Dex.ledgerNet(dex, req.ledgerB) == old(Dex.ledgerNet(dex, req.ledgerB))
      };
      case (#rem req) {
        Dex.ledgerNet(dex, req.ledgerA) == old(Dex.ledgerNet(dex, req.ledgerA)) and
        Dex.ledgerNet(dex, req.ledgerB) == old(Dex.ledgerNet(dex, req.ledgerB))
      }
    };
  {
    Dex.liquidity(dex, caller, request)
  };

  public func quotePreservesLocalAccounting(
    dex : Dex.State,
    ledgerIn : Principal,
    ledgerOut : Principal,
    amountIn : Nat,
    minAmountOut : Nat
  ) : Types.Result<Types.QuoteReceipt, Types.QuoteError>
    requires true;
    ensures Dex.controllerOf(dex) == old(Dex.controllerOf(dex));
    ensures Dex.ledgerNet(dex, ledgerIn) == old(Dex.ledgerNet(dex, ledgerIn));
    ensures Dex.ledgerNet(dex, ledgerOut) == old(Dex.ledgerNet(dex, ledgerOut));
    ensures Dex.localObligation(dex, ledgerIn) == old(Dex.localObligation(dex, ledgerIn));
    ensures Dex.localObligation(dex, ledgerOut) == old(Dex.localObligation(dex, ledgerOut));
    ensures Dex.pendingOut(dex, ledgerIn) == old(Dex.pendingOut(dex, ledgerIn));
    ensures Dex.pendingOut(dex, ledgerOut) == old(Dex.pendingOut(dex, ledgerOut));
  {
    Dex.quote(dex, ledgerIn, ledgerOut, amountIn, minAmountOut)
  };

  public func quotePreservesAccountingBalance(
    dex : Dex.State,
    ledgerIn : Principal,
    ledgerOut : Principal,
    amountIn : Nat,
    minAmountOut : Nat
  ) : Types.Result<Types.QuoteReceipt, Types.QuoteError>
    requires Dex.accountingBalanced(dex, ledgerIn);
    requires Dex.accountingBalanced(dex, ledgerOut);
    ensures Dex.accountingBalanced(dex, ledgerIn);
    ensures Dex.accountingBalanced(dex, ledgerOut);
  {
    let beforeNetIn = Dex.ledgerNet(dex, ledgerIn);
    let beforeObligationIn = Dex.localObligation(dex, ledgerIn);
    let beforePendingIn = Dex.pendingOut(dex, ledgerIn);
    let beforeDustIn = Dex.abandonedDust(dex, ledgerIn);
    let beforeNetOut = Dex.ledgerNet(dex, ledgerOut);
    let beforeObligationOut = Dex.localObligation(dex, ledgerOut);
    let beforePendingOut = Dex.pendingOut(dex, ledgerOut);
    let beforeDustOut = Dex.abandonedDust(dex, ledgerOut);
    assert beforeNetIn == beforeObligationIn + beforePendingIn + beforeDustIn;
    assert beforeNetOut == beforeObligationOut + beforePendingOut + beforeDustOut;
    let out = Dex.quote(dex, ledgerIn, ledgerOut, amountIn, minAmountOut);
    unchangedDeltasPreserveAccountingBalance(
      beforeNetIn,
      beforeObligationIn,
      beforePendingIn,
      beforeDustIn,
      Dex.ledgerNet(dex, ledgerIn),
      Dex.localObligation(dex, ledgerIn),
      Dex.pendingOut(dex, ledgerIn),
      Dex.abandonedDust(dex, ledgerIn)
    );
    unchangedDeltasPreserveAccountingBalance(
      beforeNetOut,
      beforeObligationOut,
      beforePendingOut,
      beforeDustOut,
      Dex.ledgerNet(dex, ledgerOut),
      Dex.localObligation(dex, ledgerOut),
      Dex.pendingOut(dex, ledgerOut),
      Dex.abandonedDust(dex, ledgerOut)
    );
    assert Dex.accountingBalanced(dex, ledgerIn);
    assert Dex.accountingBalanced(dex, ledgerOut);
    out
  };

  public func liquidityMovesPoolSharesWhenSlotsDistinct(
    dex : Dex.State,
    caller : Principal,
    request : Types.LiquidityRequest
  ) : Types.Result<Types.LiquidityReceipt, Types.LiquidityError>
    requires true;
    ensures switch (result) {
      case (#ok(#added receipt)) {
        (
          BalanceBook.recordKey(caller, receipt.poolKey) !=
            BalanceBook.recordKey(caller, AssetKey.ledger(receipt.ledgerA)) and
          BalanceBook.recordKey(caller, receipt.poolKey) !=
            BalanceBook.recordKey(caller, AssetKey.ledger(receipt.ledgerB))
        ) ==>
          Dex.localBalance(dex, caller, receipt.poolKey) ==
            old(Dex.localBalance(dex, caller, receipt.poolKey)) + receipt.shares
      };
      case (#ok(#removed receipt)) {
        (
          BalanceBook.recordKey(caller, receipt.poolKey) !=
            BalanceBook.recordKey(caller, AssetKey.ledger(receipt.ledgerA)) and
          BalanceBook.recordKey(caller, receipt.poolKey) !=
            BalanceBook.recordKey(caller, AssetKey.ledger(receipt.ledgerB))
        ) ==>
          Dex.localBalance(dex, caller, receipt.poolKey) + receipt.shares ==
            old(Dex.localBalance(dex, caller, receipt.poolKey))
      };
      case (#err(_)) { true }
    };
  {
    Dex.liquidity(dex, caller, request)
  };

  public func lpSupplyAddDeltasPreserveBalance(
    oldTotalShares : Nat,
    oldUserShares : Nat,
    oldLockedShares : Nat,
    newTotalShares : Nat,
    newUserShares : Nat,
    newLockedShares : Nat,
    mintedUserShares : Nat,
    mintedLockedShares : Nat
  ) : ()
    requires oldTotalShares == oldUserShares + oldLockedShares;
    requires newTotalShares == oldTotalShares + mintedUserShares + mintedLockedShares;
    requires newUserShares == oldUserShares + mintedUserShares;
    requires newLockedShares == oldLockedShares + mintedLockedShares;
    ensures newTotalShares == newUserShares + newLockedShares;
  {
    assert newTotalShares ==
      ((oldUserShares + oldLockedShares) + mintedUserShares) + mintedLockedShares;
    NatAxiom.addAssoc(oldUserShares, oldLockedShares, mintedUserShares);
    NatAxiom.addComm(oldLockedShares, mintedUserShares);
    NatAxiom.addAssoc(oldUserShares, mintedUserShares, oldLockedShares);
    assert (oldUserShares + oldLockedShares) + mintedUserShares ==
      (oldUserShares + mintedUserShares) + oldLockedShares;
    NatAxiom.addAssoc(oldUserShares + mintedUserShares, oldLockedShares, mintedLockedShares);
    assert ((oldUserShares + mintedUserShares) + oldLockedShares) + mintedLockedShares ==
      (oldUserShares + mintedUserShares) + (oldLockedShares + mintedLockedShares);
    assert newTotalShares == newUserShares + newLockedShares
  };

  public func lpSupplyRemoveDeltasPreserveBalance(
    oldTotalShares : Nat,
    oldUserShares : Nat,
    oldLockedShares : Nat,
    newTotalShares : Nat,
    newUserShares : Nat,
    newLockedShares : Nat,
    burnedUserShares : Nat
  ) : ()
    requires oldTotalShares == oldUserShares + oldLockedShares;
    requires oldTotalShares == newTotalShares + burnedUserShares;
    requires oldUserShares == newUserShares + burnedUserShares;
    requires newLockedShares == oldLockedShares;
    ensures newTotalShares == newUserShares + newLockedShares;
  {
    assert newTotalShares + burnedUserShares ==
      (newUserShares + burnedUserShares) + oldLockedShares;
    NatAxiom.addAssoc(newUserShares, burnedUserShares, oldLockedShares);
    NatAxiom.addComm(burnedUserShares, oldLockedShares);
    NatAxiom.addAssoc(newUserShares, oldLockedShares, burnedUserShares);
    assert (newUserShares + burnedUserShares) + oldLockedShares ==
      (newUserShares + oldLockedShares) + burnedUserShares;
    NatAxiom.addCancelRightEq(newTotalShares, newUserShares + oldLockedShares, burnedUserShares);
    assert newTotalShares == newUserShares + newLockedShares
  };
}
