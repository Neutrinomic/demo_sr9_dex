    dex : Dex.State,
    ledger : Principal,
    err : ICRCLedger.TransferFromError
  ) : Types.Result<Types.DepositReceipt, Types.DepositError>
    requires Dex.accountingBalanced(dex, ledger);
    ensures Dex.accountingBalanced(dex, ledger);
    ensures switch (result) {
      case (#ok(_)) { false };
      case (#err(_)) { true }
    };
  {
    let beforeNet = Dex.ledgerNet(dex, ledger);
    let beforeObligation = Dex.localObligation(dex, ledger);
    let beforePending = Dex.pendingOut(dex, ledger);
    let beforeDust = Dex.abandonedDust(dex, ledger);
    assert beforeNet == beforeObligation + beforePending + beforeDust;
    let out = Dex.finishDepositErr(dex, ledger, err);
    unchangedDeltasPreserveAccountingBalance(
      beforeNet,
      beforeObligation,
      beforePending,
      beforeDust,
      Dex.ledgerNet(dex, ledger),
      Dex.localObligation(dex, ledger),
      Dex.pendingOut(dex, ledger),
      Dex.abandonedDust(dex, ledger)
    );
    assert Dex.accountingBalanced(dex, ledger);
    out
  };

