{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["bun-types"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "common/**/*.ts",
    "fixtures/**/*.ts",
    "fixtures/**/*.d.ts",
    "harness/**/*.ts",
    "spec/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
